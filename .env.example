# =============================================================================
# WhatsApp AI Agent — Environment Variables
# Copy this file to `.env` (local) or add each variable in Vercel (production).
# NEVER commit `.env` to GitHub.
# =============================================================================

# --- Meta WhatsApp Business API ---
# Permanent token from Meta Business Suite > System Users (see README)
WHATSAPP_ACCESS_TOKEN=

# Phone Number ID from developers.facebook.com > App > WhatsApp > API Setup
WHATSAPP_PHONE_NUMBER_ID=

# Any secret string YOU choose; must match Meta webhook "Verify token"
WHATSAPP_VERIFY_TOKEN=your_verify_token_here

# --- AI (OpenRouter) ---
# API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model ID from https://openrouter.ai/models (recommended below)
AI_MODEL=google/gemini-2.0-flash-001

# --- Supabase (3 required — see README "Supabase" section Steps 6–8) ---
# Dashboard: Project Settings (gear) → API
#   Project URL                    → NEXT_PUBLIC_SUPABASE_URL
#   Project API keys → anon public → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   Project API keys → service_role secret → SUPABASE_SERVICE_ROLE_KEY
# Do NOT use Database password or Connection string here.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
PORT=3000
# Local: http://localhost:3000 | Production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
